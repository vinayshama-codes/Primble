# Copy to .env for local development. NEVER commit .env to source control.
# All variables marked [REQUIRED] must be set in production.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/acordly  # [REQUIRED]

# ── App environment ───────────────────────────────────────────────────────────
ENVIRONMENT=development  # Set to "production" in prod (enables CORS enforcement)

# ── Frontend / CORS ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# In production: ALLOWED_ORIGINS=https://app.acordly.ai  [REQUIRED in production]

# ── Auth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<google_oauth_client_id>.apps.googleusercontent.com  # [REQUIRED]

# ── Field encryption (signature_data at rest) ─────────────────────────────────
# [REQUIRED] Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=<base64_fernet_key>

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<stripe_secret_key>  # [REQUIRED]
STRIPE_WEBHOOK_SECRET=<stripe_webhook_secret>  # [REQUIRED]
STRIPE_BILLING_PORTAL_URL=https://billing.stripe.com/p/login/

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=<aws_access_key_id>  # [REQUIRED if using Textract/S3/SQS]
AWS_SECRET_ACCESS_KEY=<aws_secret_access_key>  # [REQUIRED if using Textract/S3/SQS]
AWS_REGION=us-east-1
AWS_S3_BUCKET=acordly-documents
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com   # [REQUIRED for R2] Cloudflare R2 endpoint
STORAGE_ACCESS_KEY=<r2-access-key-id>                              # [REQUIRED for R2] R2 Access Key ID
STORAGE_SECRET_KEY=<r2-secret-access-key>                          # [REQUIRED for R2] R2 Secret Access Key

# ── Job Queue ─────────────────────────────────────────────────────────────────
JOB_QUEUE_BACKEND=db  # local_file | memory | db | sqs
# Required only when JOB_QUEUE_BACKEND=sqs:
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/acordly-jobs

ENABLE_ASYNC_PROCESSING=false  # Set true to return 202 + run jobs in worker.py

# ── LLM / OCR ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=<groq_api_key>  # [REQUIRED]
LLM_PROVIDER=groq  # groq | claude | openai
OCR_PROVIDER=easyocr  # easyocr | textract | google_vision

# ── Redis (rate limiting / caching) ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=<admin@example.com>  # [REQUIRED] comma-separated admin emails

# ── Dev routes (NEVER enable in production) ───────────────────────────────────
DEV_ROUTES_ENABLED=false

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
MAX_FILES_PER_UPLOAD=10

# ── Worker tuning ─────────────────────────────────────────────────────────────
WORKER_POLL_INTERVAL=5
WORKER_MAX_JOBS_PER_CYCLE=3
